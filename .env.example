# distributed-donut configuration
#
# Copy to .env and adjust.


# Precedence: command-line flags > environment variables > the defaults below.
# Every variable has an equivalent flag (e.g. DONUT_TASK_TIMEOUT == -task-timeout).

# HTTP listen address. Set DONUT_ADDR for a full "host:port" (host optional),
# or set PORT alone (common on PaaS) to listen on ":$PORT". DONUT_ADDR wins.
DONUT_ADDR=:8080
# PORT=8080

# How long a render batch may be outstanding before it's reassigned to another
# client. Go duration string (e.g. 500ms, 2s).
DONUT_TASK_TIMEOUT=2s

# Pacing/cooldown between broadcasts; also bounds the dispatcher's pre-fetch sleep.
DONUT_BROADCAST_INTERVAL=4s

# Seconds of frames to gather before the very first broadcast. The excess over
# DONUT_BROADCAST_SECONDS becomes the clients' playback buffer.
DONUT_FIRST_BROADCAST_SECONDS=6

# Seconds of frames each subsequent broadcast (and dispatch round) covers.
DONUT_BROADCAST_SECONDS=4

# Max time to wait for in-flight requests to drain on shutdown before forcing it.
DONUT_SHUTDOWN_TIMEOUT=10s
