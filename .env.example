# distributed-donut — environment configuration
#
# Every var below mirrors a command-line flag. Precedence is:
#   flag  >  environment variable  >  built-in default
# The values shown here ARE the built-in defaults, so an unset var behaves
# exactly as written. Durations use Go syntax: "2s", "150ms", "4s".

# ── Server / HTTP ────────────────────────────────────────────────────────────
# Listen address. DONUT_ADDR wins if set; otherwise PORT (the common PaaS
# convention) is used as ":$PORT"; otherwise the server binds ":8080".
DONUT_ADDR=:8080
# PORT=8080

# Max time to drain in-flight requests on shutdown (SIGINT/SIGTERM).
DONUT_SHUTDOWN_TIMEOUT=10s

# ── Pipeline timing ──────────────────────────────────────────────────────────
# How long a render batch may be outstanding before it's reassigned to another
# worker.
DONUT_TASK_TIMEOUT=2s

# Pacing/cooldown between broadcasts (also the upper bound on dispatcher pacing).
DONUT_BROADCAST_INTERVAL=4s

# Seconds of frames gathered before the FIRST broadcast; the surplus over
# DONUT_BROADCAST_SECONDS becomes each client's playback cushion.
DONUT_FIRST_BROADCAST_SECONDS=6

# Seconds of frames each subsequent broadcast covers (and each dispatch round).
DONUT_BROADCAST_SECONDS=4

# ── Fleet telemetry (server → all clients) ───────────────────────────────────
# How often the live connected-client count is broadcast. 0 disables it.
DONUT_CLIENT_COUNT_INTERVAL=2s

# How often ring-buffer fullness is broadcast. 0 disables it.
DONUT_BUFFER_FULLNESS_INTERVAL=2s

# ── Limits & safety ──────────────────────────────────────────────────────────
# Max concurrent worker connections. Connections past the cap are rejected with
# a "try again later" close before any per-connection goroutine is spawned.
# 0 disables the cap (unbounded).
DONUT_MAX_CLIENTS=10000

# ── Logging ──────────────────────────────────────────────────────────────────
# Verbosity: debug, info, warn, error.
DONUT_LOG_LEVEL=info

# Minimum spacing between repeats of any single debug log line, to curb hot-path
# spam. <= 0 disables sampling (every line passes).
DONUT_LOG_SAMPLE_INTERVAL=2s